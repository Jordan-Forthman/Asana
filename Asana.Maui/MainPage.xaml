<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Asana.Maui.MainPage"
             NavigatedTo="ContentPage_NavigatedTo"
             NavigatedFrom="ContentPage_NavigatedFrom">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <!-- ToDo Tool Bar-->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Label Margin ="10" Grid.Column="0" Text="Show Completed Tasks:"/>
                    <CheckBox Margin="5" Grid.Column="1" IsChecked="{Binding IsShowCompleted}"/>
                </Grid>
                <!-- ToDo Label -->
                <Label Grid.Row="1" Text="ToDo's" FontSize="Medium" FontAttributes="Bold" Margin="0,20,0,0"/>
                <!-- ToDo List-->
                <ListView
                Grid.Row="2"
                ItemsSource="{Binding ToDos}"
                SelectedItem="{Binding SelectedToDo}"
                >
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <ViewCell>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="10*"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox IsChecked="{Binding Model.IsCompleted}" Grid.Column="0"/>

                                    <Grid Grid.Column="1">
                                        <Grid.RowDefinitions>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                        </Grid.RowDefinitions>
                                        <Label TextColor="Red" Grid.Row="0" Text="{Binding Model.Name}"/>
                                        <Label Grid.Row="1" Text="{Binding Model.Description}"/>
                                    </Grid>

                                    <Button Grid.Column="2" Text="Delete" Clicked="InLineDeleteClicked" Command="{Binding DeleteCommand}"/>
                                </Grid>
                            </ViewCell>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <!-- Projects Tool Bar-->
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Label Margin="10" Grid.Column="0" Text="Show Completed Projects:" VerticalOptions="Center"/>
                    <CheckBox Margin="5" Grid.Column="1" IsChecked="{Binding IsShowCompletedProjects}"/>
                </Grid>
                <!-- Projects Label -->
                <Label Grid.Row="4" Text="Projects" FontSize="Medium" FontAttributes="Bold" Margin="0,20,0,0"/>
                <!-- Projects List -->
                <ListView Grid.Row="5"
                          ItemsSource="{Binding Projects}"
                          SelectedItem="{Binding SelectedProject}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <ViewCell>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="10*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox IsChecked="{Binding Model.IsCompleted}" Grid.Column="0"/>
                                    <Grid Grid.Column="1">
                                        <Grid.RowDefinitions>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                        </Grid.RowDefinitions>
                                        <Label TextColor="Blue" Grid.Row="0" Text="{Binding Model.Name}"/>
                                        <Label Grid.Row="1" Text="{Binding Model.Description}"/>
                                    </Grid>
                                    <Label Grid.Column="2" Text="{Binding Model.CompletePercent, StringFormat='{0}% Complete'}" VerticalOptions="Center"/>
                                    <Button Grid.Column="3" Text="Delete" Clicked="DeleteProjectClicked" Command="{Binding DeleteCommand}"/>
                                </Grid>
                            </ViewCell>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <!-- Button Bar -->
                <VerticalStackLayout Grid.Row="6">
                    <Button Text="Add New ToDo" Clicked="AddNewClicked"/>
                    <Button Text="Edit Selected ToDo" Clicked="EditClicked"/>
                    <Button Text="Delete Selected ToDo" Clicked="DeleteClicked"/>
                    <Button Text="Add New Project" Clicked="AddProjectClicked"/>
                    <Button Text="Edit Selected Project" Clicked="EditProjectClicked"/>
                    <Button Text="Delete Selected Project" Clicked="DeleteProjectClicked"/>
                </VerticalStackLayout>
            </Grid>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
